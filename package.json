{
  "name": "clue-notes",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,ts,vue,scss,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "typecheck:strict": "vue-tsc --noEmit -p tsconfig.strict.json",
    "test:visual": "docker compose run --rm playwright npx playwright test",
    "test:visual:update": "docker compose run --rm playwright npx playwright test --update-snapshots"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pluralize": "^8.0.0",
    "uuid": "^13.0.0",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@iconify-json/akar-icons": "^1.2.7",
    "@iconify-json/eva": "^1.2.3",
    "@iconify-json/famicons": "^1.2.2",
    "@iconify-json/fluent-emoji-flat": "^1.2.5",
    "@iconify-json/hugeicons": "^1.2.22",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/icons8": "^1.2.1",
    "@iconify-json/material-symbols": "^1.2.44",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ooui": "^1.2.13",
    "@iconify-json/ri": "^1.2.7",
    "@iconify-json/solar": "^1.2.5",
    "@iconify-json/system-uicons": "^1.2.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "sass-embedded": "^1.93.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "unplugin-icons": "^22.5.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.1.11",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-tsc": "^3.2.5"
  }
